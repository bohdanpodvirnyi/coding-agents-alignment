{
  "name": "coding-agents-alignment",
  "version": "0.1.0",
  "description": "Ambient GitHub Project alignment for coding agents (pi + Claude Code)",
  "type": "module",
  "main": "./dist/extensions/alignment/index.js",
  "files": [
    "dist/",
    "claude-code-plugin/",
    "README.md",
    "LICENSE",
    ".coding-agents-alignment.example.json"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "github-projects",
    "coding-agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./dist/extensions"
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
